# ===== OPENAI =====
# API key từ https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ===== TELEGRAM =====
# Bot token từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF...

# ===== CÀI ĐẶT PHÂN TÍCH =====
# Ngưỡng xác suất ảnh hưởng BTC để gửi alert (mặc định 90%)
BTC_INFLUENCE_THRESHOLD=90

# ===== TRUTH SOCIAL =====
# CÁCH 1 (TỲ CHỌN): Cung cấp access token trực tiếp
# Lấy bằng cách đăng nhập Truth Social và lấy Bearer token từ DevTools
# TRUTH_SOCIAL_ACCESS_TOKEN=...

# CÁCH 2 (KHUYẾN NGHỊ): Cung cấp username/password
# App sẽ tự động login bằng Puppeteer (headless browser) và lấy token
# Token sẽ được tự động refresh khi hết hạn
TRUTHSOCIAL_USERNAME=trandinhnamz
TRUTHSOCIAL_PASSWORD=Meik9occod@
